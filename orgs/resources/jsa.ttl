PREFIX aarr: <https://data.idnau.org/pid/vocab/aarr/> 
PREFIX dcat: <http://www.w3.org/ns/dcat#> 
PREFIX dcterms: <http://purl.org/dc/terms/> 
PREFIX id: <http://id.loc.gov/vocabulary/identifiers/> 
PREFIX schema: <https://schema.org/> 
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#> 

<https://linked.data.gov.au/org/jsa>
    a schema:Organization ;
    dcat:qualifiedRelation [
        a dcat:Relationship ;
            dcat:hadRole aarr:partOf ;
            schema:agent <https://linked.data.gov.au/org/dewr> 
        ] ;
    schema:description "Jobs and Skills Australia was established in 2022 under the Jobs and Skills Australia Act 2022." ;
    schema:name "Jobs and Skills Australia"@en ;
    schema:alternateName "JSA" ;
    schema:url "https://www.jobsandskills.gov.au"^^xsd:anyURI ;
    dcterms:isRequiredBy "https://www.legislation.gov.au/C2022A00051"^^xsd:anyURI 
.
